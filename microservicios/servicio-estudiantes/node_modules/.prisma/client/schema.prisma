generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Salon {
  id_salon   Int      @id @default(autoincrement())
  grado      String
  seccion    String
  id_maestro Int
  alumnos    Alumno[]

  @@unique([grado, seccion])
}

model Alumno {
  id_alumno      Int      @id @default(autoincrement())
  nombre         String
  apellido       String
  fecha_creacion DateTime @default(now())

  id_salon Int
  salon    Salon @relation(fields: [id_salon], references: [id_salon])
}
